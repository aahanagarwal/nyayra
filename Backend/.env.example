# Comma-separated pool. Rotates automatically on quota/expiry.
# Durable keys look like AIza...; AQ.* are short-lived ephemeral tokens.
GEMINI_API_KEYS=AIzaKEY1,AQ.EPHEMERAL1,AQ.EPHEMERAL2

APP_SECRET_KEY=change-me
DEBUG_TOKEN=change-me
DATABASE_URL=sqlite+aiosqlite:///./nyayra.db
STORAGE_PATH=./storage

# Provisioned by the Twilio dev. Backend only validates + sends.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
PUBLIC_BASE_URL=http://localhost:8000

# Per-stage model. Flip council to gemma-4-26b-a4b-it for the Gemma story.
MODEL_PREP=gemini-flash-lite-latest
MODEL_ACT_SELECT=gemini-flash-lite-latest
MODEL_COUNCIL=gemini-3.5-flash
MODEL_VERIFY=gemini-3.5-flash
MODEL_DRAFT=gemini-3.5-flash
MODEL_UNMASK=gemini-flash-lite-latest
MODEL_AUDIO=gemini-2.5-flash-native-audio-latest
MODEL_EMBED=gemini-embedding-001
MAX_CONCURRENT_CALLS=8
